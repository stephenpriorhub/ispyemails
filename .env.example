# iSpyEmails — environment variables
# Copy to `.env` for local dev; set these on Railway for the live `ispy-emails` service.
# (Real .env / .env.local files are gitignored — this .example is safe to commit.)

# ─── Database (Prisma / Postgres) ────────────────────────────────────────────
DATABASE_URL=

# ─── Gmail API ───────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Claude API (email classification / learning extraction) ─────────────────
ANTHROPIC_API_KEY=

# ─── OxfordHub auth ──────────────────────────────────────────────────────────
NEXTAUTH_SECRET=
NEXTAUTH_URL=

# ─── Cron protection (email-sync / brain-sync endpoints) ─────────────────────
CRON_SECRET=

# ─── Email alerts (Resend) ───────────────────────────────────────────────────
RESEND_API_KEY=

# ─── Brain vault integration (App-to-Brain Learning Loop) ────────────────────
# Shared token authenticating app -> Brain API. Same value as brain-map's HUB_API_TOKEN.
HUB_API_TOKEN=
# Base URL of the shared Brain API ("the librarian"), hosted in brain-map.
# The nightly/on-demand sync POSTs learnings + per-guru `guru-live-intel` to
# `${BRAIN_API_URL}/api/intelligence`. Defaults to https://brain.oxfordhub.app if unset.
# (Legacy name BRAIN_URL is still read as a fallback for back-compat.)
BRAIN_API_URL=https://brain.oxfordhub.app
