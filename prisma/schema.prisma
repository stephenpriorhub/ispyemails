generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth (managed by OxfordHub) ─────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String
  role      Role     @default(USER)
  status    Status   @default(ACTIVE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
enum Role {
  ADMIN
  USER
}

enum Status {
  ACTIVE
  SUSPENDED
}

// ─── Gmail ────────────────────────────────────────────────────────────────────

model GmailAccount {
  id           String    @id @default(cuid())
  email        String    @unique
  accessToken  String    @db.Text
  refreshToken String    @db.Text
  tokenExpiry  DateTime?
  historyId    String?
  lastSyncAt   DateTime?
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

// ─── Publishers ───────────────────────────────────────────────────────────────

enum PublisherType {
  INTERNAL          // your own company
  COMPETITOR        // direct competitor
  AFFILIATE_MARKETER // third-party affiliate
}

model Publisher {
  id                 String        @id @default(cuid())
  name               String        @unique
  type               PublisherType @default(COMPETITOR)
  domains            String[]
  knownFromAddresses String[]
  website            String?
  notes              String?
  isConfirmed        Boolean       @default(false)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  lists  List[]
  emails Email[]
}

// ─── Lists (newsletters) ──────────────────────────────────────────────────────

enum ListCategory {
  FREE_EDITORIAL
  PAID_EDITORIAL
  HOTLIST
  MARKETING_FILE
}

model List {
  id          String       @id @default(cuid())
  name        String       @unique
  category    ListCategory @default(FREE_EDITORIAL)
  publisherId String?
  publisher   Publisher?   @relation(fields: [publisherId], references: [id])
  notes       String?
  isIgnored   Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  gurus  GuruList[]
  emails Email[]
}

// ─── Gurus (editors/voices) ───────────────────────────────────────────────────

model Guru {
  id        String     @id @default(cuid())
  name      String     @unique
  bio       String?    @db.Text
  notes     String?
  isIgnored Boolean    @default(false)
  createdAt DateTime   @default(now())

  lists  GuruList[]
  emails EmailGuru[]
}

model GuruList {
  guruId    String
  listId    String
  isPrimary Boolean @default(false)
  guru      Guru    @relation(fields: [guruId], references: [id], onDelete: Cascade)
  list      List    @relation(fields: [listId], references: [id], onDelete: Cascade)
  @@id([guruId, listId])
}

// ─── Emails ───────────────────────────────────────────────────────────────────

model Email {
  id                 String     @id @default(cuid())
  gmailMessageId     String     @unique
  subject            String
  fromName           String?
  fromEmail          String
  toEmail            String?
  receivedAt         DateTime
  bodyHtml           String?    @db.Text
  bodyText           String?    @db.Text
  snippet            String?
  inboxPlacement     Placement  @default(UNKNOWN)
  publisherId        String?
  publisher          Publisher? @relation(fields: [publisherId], references: [id])
  publisherConfirmed Boolean    @default(false)
  listId             String?
  list               List?      @relation(fields: [listId], references: [id])
  listConfirmed      Boolean    @default(false)
  emailType          EmailType  @default(UNKNOWN)
  emailTypeConfirmed Boolean    @default(false)
  aiSummary          String?    @db.Text
  aiTicker           String?
  aiConfidence       Float?
  isProcessed        Boolean    @default(false)
  syncedAt           DateTime   @default(now())
  createdAt          DateTime   @default(now())

  topics EmailTopic[]
  tags   EmailTag[]
  gurus  EmailGuru[]
  offer  Offer?

  @@index([receivedAt])
  @@index([fromEmail])
  @@index([publisherId])
  @@index([listId])
  @@index([inboxPlacement])
  @@index([emailType])
}

model EmailGuru {
  emailId String
  guruId  String
  email   Email  @relation(fields: [emailId], references: [id], onDelete: Cascade)
  guru    Guru   @relation(fields: [guruId], references: [id], onDelete: Cascade)
  @@id([emailId, guruId])
}

enum Placement {
  PRIMARY
  PROMOTIONS
  SPAM
  UPDATES
  SOCIAL
  UNKNOWN
}

enum EmailType {
  LIFT_NOTE
  EDITORIAL
  PROMO
  UNKNOWN
}

// ─── Topics ───────────────────────────────────────────────────────────────────

model Topic {
  id        String       @id @default(cuid())
  name      String       @unique
  isIgnored Boolean      @default(false)
  color     String?
  synonyms  String[]
  createdAt DateTime     @default(now())
  emails    EmailTopic[]
}

model EmailTopic {
  emailId    String
  topicId    String
  confidence Float  @default(1.0)
  email      Email  @relation(fields: [emailId], references: [id], onDelete: Cascade)
  topic      Topic  @relation(fields: [topicId], references: [id], onDelete: Cascade)
  @@id([emailId, topicId])
}

// ─── Tags ─────────────────────────────────────────────────────────────────────

model Tag {
  id        String     @id @default(cuid())
  name      String     @unique
  color     String     @default("#6B7280")
  createdAt DateTime   @default(now())
  emails    EmailTag[]
}

model EmailTag {
  emailId String
  tagId   String
  email   Email  @relation(fields: [emailId], references: [id], onDelete: Cascade)
  tag     Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)
  @@id([emailId, tagId])
}

// ─── Offers ───────────────────────────────────────────────────────────────────

model Offer {
  id      String  @id @default(cuid())
  emailId String  @unique
  url     String?
  promise String? @db.Text
  ticker  String?
  email   Email   @relation(fields: [emailId], references: [id], onDelete: Cascade)
}
